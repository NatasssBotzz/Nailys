{
  "name": "naileys",
  "type": "module",
  "version": "7.0.0-rc13",
  "description": "A WebSockets library for interacting with WhatsApp Web",
  "keywords": [
    "whatsapp",
    "automation"
  ],
  "homepage": "https://github.com/NatasssBotzz/Naileys",
  "repository": {
    "url": "git@github.com:NatasssBotzz/Naileys.git"
  },
  "license": "MIT",
  "author": "Rajeh Taher",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "WAProto/index.js",
    "engine-requirements.js"
  ],
  "scripts": {
    "build": "tsc -P tsconfig.build.json && tsc-esm-fix --tsconfig=tsconfig.build.json --ext=.js",
    "postinstall": "echo '[naileys] Skipping build — menggunakan lib/ dari repo'"
  },
  "dependencies": {
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
    "async-mutex": "^0.5.0",
    "libsignal": "^6.0.0",
    "lru-cache": "^11.1.0",
    "music-metadata": "^11.12.3",
    "p-queue": "^9.0.0",
    "pino": "^9.6",
    "protobufjs": "^7.5.6",
    "whatsapp-rust-bridge": "0.5.4",
    "ws": "^8.13.0"
  },
  "optionalDependencies": {
    "archiver": "*",
    "fluent-ffmpeg": "*",
    "node-webpmux": "*",
    "sharp": "*"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/ws": "^8.0.0",
    "link-preview-js": "^4.0.4",
    "tsc-esm-fix": "^3.1.2",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "audio-decode": "^2.1.3",
    "jimp": "^1.6.1",
    "link-preview-js": "^3.0.0",
    "sharp": "*"
  },
  "peerDependenciesMeta": {
    "audio-decode": {
      "optional": true
    },
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.9.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
